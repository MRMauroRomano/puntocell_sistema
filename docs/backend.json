{
  "entities": {
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Representa un producto o equipo en inventario.",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "minStock": { "type": "number" }
      },
      "required": ["id", "name", "price", "stock"]
    },
    "Customer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Customer",
      "type": "object",
      "description": "Representa un cliente y su saldo en cuenta corriente.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "balance": { "type": "number" },
        "accountType": { "type": "string", "enum": ["martin", "toti"] },
        "accountYear": { "type": "string" }
      },
      "required": ["id", "name", "balance"]
    },
    "Sale": {
      "title": "Sale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "total": { "type": "number" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/products/{productId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/Product" },
          "description": "Productos del inventario de la tienda del usuario."
        }
      },
      {
        "path": "/users/{userId}/customers/{customerId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/Customer" },
          "description": "Clientes y saldos de la tienda del usuario."
        }
      },
      {
        "path": "/users/{userId}/sales/{saleId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/Sale" },
          "description": "Historial de ventas de la tienda del usuario."
        }
      },
      {
        "path": "/users/{userId}/expenses/{expenseId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/Expense" },
          "description": "Gastos registrados por el usuario."
        }
      },
      {
        "path": "/staff_roles/{staffId}",
        "definition": {
          "description": "Roles y permisos del personal."
        }
      }
    ]
  }
}