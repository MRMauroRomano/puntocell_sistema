
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Representa un producto o equipo en inventario.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "subCategory": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "minStock": { "type": "number" },
        "condition": { "type": "string", "enum": ["Nuevo", "Usado"] },
        "batteryHealth": { "type": "string" },
        "storage": { "type": "string" }
      },
      "required": ["id", "name", "price", "stock"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Representa un cliente y su saldo en cuenta corriente.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "balance": { "type": "number" },
        "balanceUSD": { "type": "number" },
        "accountType": { "type": "string", "enum": ["martin", "toti"] },
        "accountYear": { "type": "string" },
        "notes": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "cuit": { "type": "string" }
      },
      "required": ["id", "name", "balance"]
    },
    "AccountMovement": {
      "title": "AccountMovement",
      "description": "Representa un cargo o pago individual en la cuenta de un cliente.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["charge", "payment"] },
        "status": { "type": "string", "enum": ["pending", "paid"] },
        "referenceId": { "type": "string" }
      },
      "required": ["id", "date", "amount", "type", "status"]
    },
    "Sale": {
      "title": "Sale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "total": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["completed", "returned"] }
      }
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}/products/{productId}": {
      "schema": { "$ref": "#/backend/entities/Product" },
      "description": "Productos del inventario de la tienda del usuario."
    },
    "/users/{userId}/customers/{customerId}": {
      "schema": { "$ref": "#/backend/entities/Customer" },
      "description": "Clientes y saldos de la tienda del usuario."
    },
    "/users/{userId}/customers/{customerId}/movements/{movementId}": {
      "schema": { "$ref": "#/backend/entities/AccountMovement" },
      "description": "Historial de cargos y pagos individuales del cliente."
    },
    "/users/{userId}/sales/{saleId}": {
      "schema": { "$ref": "#/backend/entities/Sale" },
      "description": "Historial de ventas de la tienda del usuario."
    },
    "/users/{userId}/expenses/{expenseId}": {
      "schema": { "$ref": "#/backend/entities/Expense" },
      "description": "Gastos registrados por el usuario."
    },
    "/users/{userId}/settings/{settingId}": {
      "schema": { "type": "object" },
      "description": "Configuraciones de la tienda del usuario."
    }
  }
}
