
{
  "entities": {
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a single product available for sale in the store.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "subCategory": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "minStock": { "type": "number" },
        "description": { "type": "string" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "name", "price", "stock", "isActive"]
    },
    "User": {
      "title": "User",
      "type": "object",
      "description": "Store staff and administrators.",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Sale": {
      "title": "Sale",
      "type": "object",
      "description": "Sales transactions records.",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "items": { "type": "array" },
        "invoiceUrl": { "type": "string", "description": "URL of the invoice file in storage" }
      },
      "required": ["id", "date", "total", "paymentMethod"]
    },
    "CashRegister": {
      "title": "CashRegister",
      "type": "object",
      "description": "Daily cash register tracking.",
      "properties": {
        "id": { "type": "string", "description": "Format: YYYY-MM-DD" },
        "openingBalance": { "type": "number" },
        "closingBalance": { "type": "number" },
        "totalSales": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "closed"] }
      },
      "required": ["id", "openingBalance", "status"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{uid}",
        "definition": {
          "entityName": "User",
          "description": "Collection of administrators and staff members."
        }
      },
      {
        "path": "/products/{productId}",
        "definition": {
          "entityName": "Product",
          "description": "Inventory of cellphones and electronics."
        }
      },
      {
        "path": "/sales/{saleId}",
        "definition": {
          "entityName": "Sale",
          "description": "Historical record of all sales."
        }
      },
      {
        "path": "/cashregister/{dayId}",
        "definition": {
          "entityName": "CashRegister",
          "description": "Daily cash register sessions."
        }
      }
    ]
  }
}
