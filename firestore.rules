rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * REGLAS DE SEGURIDAD PARA PROTOTIPADO
     * 
     * Permitimos lectura y escritura a cualquier usuario autenticado (incluyendo anónimos)
     * en todas las colecciones para facilitar el desarrollo del sistema de gestión.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Permitir acceso a todas las colecciones principales del sistema
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}