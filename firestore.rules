
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Permitir acceso total a productos, ventas, usuarios y caja para usuarios autenticados
    // Esto facilita el desarrollo del prototipo de gestión.
    match /products/{productId} {
      allow read, write: if isSignedIn();
    }
    
    match /users/{uid} {
      allow read, write: if isSignedIn();
    }
    
    match /sales/{saleId} {
      allow read, write: if isSignedIn();
    }
    
    match /cashregister/{dayId} {
      allow read, write: if isSignedIn();
    }

    // Regla de respaldo para cualquier otra colección
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
