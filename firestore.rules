rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * REGLAS DE SEGURIDAD PARA PROTOTIPADO
     * 
     * Permitimos lectura y escritura a cualquier usuario autenticado para facilitar el desarrollo.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    match /roles_storeStaff/{staffId} {
      allow read, write: if isSignedIn();
    }

    match /products/{productId} {
      allow read, write: if isSignedIn();

      match /inventoryMovements/{movementId} {
        allow read, write: if isSignedIn();
      }
    }

    match /customers/{customerId} {
      allow read, write: if isSignedIn();

      match /accountMovements/{movementId} {
        allow read, write: if isSignedIn();
      }
    }

    match /sales/{saleId} {
      allow read, write: if isSignedIn();

      match /saleItems/{saleItemId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}