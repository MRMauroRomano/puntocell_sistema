rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Función auxiliar para verificar si el usuario está autenticado
    function isSignedIn() {
      return request.auth != null;
    }

    // Reglas para datos segmentados por usuario (Multi-tenancy)
    // Permite acceso total al usuario sobre sus propios documentos en cualquier subcolección
    match /users/{userId}/{document=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    
    // Reglas para roles de personal
    match /staff_roles/{staffId} {
      allow read, write: if isSignedIn() && request.auth.uid == staffId;
    }

    // Reglas de respaldo para colecciones raíz (compatibilidad y compartido)
    match /products/{productId} {
      allow read, write: if isSignedIn();
    }
    match /customers/{customerId} {
      allow read, write: if isSignedIn();
    }
    match /sales/{saleId} {
      allow read, write: if isSignedIn();
    }
    match /settings/{settingId} {
      allow read, write: if isSignedIn();
    }
    match /expenses/{expenseId} {
      allow read, write: if isSignedIn();
    }
    
    // Despliegue de seguridad forzado: 2026-03-11_v3 (Corrección multitenancy)
  }
}