
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Permite acceso total a un usuario solo sobre sus propios documentos
    match /users/{userId}/{allSubcollections=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    
    // Mantenemos compatibilidad con roles si fuera necesario, 
    // pero la prioridad es la segmentación por usuario.
    match /staff_roles/{staffId} {
      allow read, write: if isSignedIn() && request.auth.uid == staffId;
    }
  }
}
