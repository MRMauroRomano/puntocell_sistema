
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    match /products/{productId} {
      allow read, write: if isSignedIn();
    }
    
    match /users/{uid} {
      allow read, write: if isSignedIn();
    }
    
    match /customers/{customerId} {
      allow read, write: if isSignedIn();
    }
    
    match /sales/{saleId} {
      allow read, write: if isSignedIn();
    }
    
    match /expenses/{expenseId} {
      allow read, write: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
